# ==========================================
# EdgeHub - Environment Variables Template
# ==========================================

# ------------------------------------------
# [REQUIRED] Database Configuration
# ------------------------------------------
# Connection string for PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
POSTGRES_DB=edge-hub
POSTGRES_USER=your-user
POSTGRES_PASSWORD=your-password

# ------------------------------------------
# [REQUIRED] Security and Authentication
# ------------------------------------------
# If this key is not set, the container will refuse to start.
# Used to access the web Dashboard as an administrator.
ADMIN_API_KEY=your-super-secret-admin-key

# ------------------------------------------
# [REQUIRED FOR PROD] Network and CORS
# ------------------------------------------
# Allowed domains for API communication (frontend Dashboard), comma-separated.
# Default: * (accepts all, highly discouraged and insecure for production).
# Ensure this is set correctly, and remember to execute the DNS route command 
# to properly direct traffic to your specified domain.
# Example: CORS_ORIGINS=http://localhost,https://dashboard.yourdomain.com
CORS_ORIGINS=*

# ------------------------------------------
# [OPTIONAL] Agent JWT Security
# ------------------------------------------
# If omitted, the server will generate a random temporary secret at startup.
# WARNING: If generated randomly, restarting the container will 
# invalidate all active agent sessions!
JWT_SECRET_KEY=put-a-long-random-string-here

# JWT signature algorithm (default: HS256)
# JWT_ALGORITHM=HS256

# Agent token expiration time in minutes (default: 1 year)
# JWT_EXPIRE_MINUTES=525600

# ------------------------------------------
# [OPTIONAL] Monitoring Settings (Heartbeat)
# ------------------------------------------
# Allowed delay in seconds before marking a node as "offline" (default: 100)
# NODE_OFFLINE_THRESHOLD_SECONDS=100

# Frequency of the background offline-check loop in seconds (default: 30)
# OFFLINE_CHECK_INTERVAL_SECONDS=30

# Number of days to retain historical heartbeats in the database before cleanup (default: 7)
# HEARTBEAT_RETENTION_DAYS=7

# Port exposing the dashboard (default: 80)
# EDGEHUB_PORT=80