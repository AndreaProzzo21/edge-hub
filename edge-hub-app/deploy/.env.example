# ==========================================
# EdgeHub - Environment Variables Template
# ==========================================

# ------------------------------------------
# [OBBLIGATORIO] Database Configuration
# ------------------------------------------
# Stringa di connessione per PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
POSTGRES_DB=edge-hub
POSTGRES_USER=your-user
POSTGRES_PASSWORD=your-password

# ------------------------------------------
# [OBBLIGATORIO] Sicurezza e Autenticazione
# ------------------------------------------
# Se questa chiave non è valorizzata, il container rifiuterà di avviarsi.
# Serve per accedere alla Dashboard web come amministratore.
ADMIN_API_KEY=your-super-secret-admin-key

# ------------------------------------------
# [OBBLIGATORIO PER PROD] Rete e CORS
# ------------------------------------------
# Domini autorizzati a comunicare con l'API (Dashboard frontend), separati da virgola.
# Default: * (accetta tutto, sconsigliato e insicuro in produzione).
# Assicurati di impostare correttamente questo valore e ricorda il comando per
# la route DNS, altrimenti il traffico non verrà instradato verso questo dominio.
# Esempio: CORS_ORIGINS=http://localhost,https://dashboard.tuodominio.com
CORS_ORIGINS=*

# ------------------------------------------
# [OPZIONALE] Sicurezza JWT per gli Agenti
# ------------------------------------------
# Se omesso, il server genererà un secret random temporaneo ad ogni avvio.
# ATTENZIONE: Se generato randomicamente, un riavvio del container 
# invaliderà le sessioni attive degli agenti!
JWT_SECRET_KEY=put-a-long-random-string-here

# Algoritmo di firma per i JWT (default: HS256)
# JWT_ALGORITHM=HS256

# Scadenza del token degli agenti in minuti (default: 10 anni)
# JWT_EXPIRE_MINUTES=5256000

# ------------------------------------------
# [OPZIONALE] Impostazioni di Monitoraggio (Heartbeat)
# ------------------------------------------
# Secondi di ritardo consentiti prima di dichiarare un nodo "offline" (default: 100)
# NODE_OFFLINE_THRESHOLD_SECONDS=100

# Frequenza del ciclo di controllo in background (default: 30)
# OFFLINE_CHECK_INTERVAL_SECONDS=30