      "post": {
        "tags": [
          "agents"
        ],
        "summary": "Agent Telemetry Ingestion",
        "description": "Primary endpoint for edge agents to stream hardware utilization metrics, Docker/K8s states, and update their online presence. Strictly requires a valid JWT Bearer token.",
