  "components": {
    "schemas": {
      "AgentRegisterRequest": {
        "properties": {
          "registration_token": {
            "type": "string",
            "minLength": 1,
            "title": "Registration Token"
          },
          "hostname": {
            "type": "string",
            "maxLength": 256,
            "minLength": 1,
            "title": "Hostname"
          },
          "description": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 512
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "agent_type": {
            "type": "string",
            "pattern": "^(linux|docker|kubernetes)$",
            "title": "Agent Type"
          },
          "agent_version": {
            "type": "string",
            "maxLength": 64,
            "title": "Agent Version"
          },
          "os": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 128
              },
              {
                "type": "null"
              }
            ],
            "title": "Os"
          },
          "arch": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 32
              },
              {
                "type": "null"
              }
            ],
            "title": "Arch"
          }
        },
        "type": "object",
        "required": [
          "registration_token",
          "hostname",
          "agent_type",
          "agent_version"
        ],
        "title": "AgentRegisterRequest"
      },
      "AgentRegisterResponse": {
        "properties": {
          "node_id": {
            "type": "string",
            "title": "Node Id"
          },
          "agent_token": {
            "type": "string",
            "title": "Agent Token"
          }
        },
        "type": "object",
        "required": [
          "node_id",
          "agent_token"
        ],
        "title": "AgentRegisterResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HeartbeatRecord": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "node_id": {
            "type": "string",
            "title": "Node Id"
          },
          "cpu_usage": {
            "type": "number",
            "title": "Cpu Usage"
          },
          "memory_usage": {
            "type": "number",
            "title": "Memory Usage"
          },
          "disk_usage": {
            "type": "number",
            "title": "Disk Usage"
          },
          "uptime_seconds": {
            "type": "number",
            "title": "Uptime Seconds"
          },
          "ip_address": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ip Address"
          },
          "extra_data": {
            "anyOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Extra Data"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          }
        },
        "type": "object",
        "required": [
          "id",
          "node_id",
          "cpu_usage",
          "memory_usage",
          "disk_usage",
          "uptime_seconds",
          "ip_address",
          "extra_data",
          "timestamp"
        ],
        "title": "HeartbeatRecord",
        "description": "Schema utilized for historical telemetry records returned by the GET /nodes/{id}/heartbeats endpoint."
      },
      "HeartbeatRequest": {
        "properties": {
          "cpu_usage": {
            "type": "number",
            "maximum": 100,
            "minimum": 0,
            "title": "Cpu Usage"
          },
          "memory_usage": {
            "type": "number",
            "maximum": 100,
            "minimum": 0,
            "title": "Memory Usage"
          },
          "disk_usage": {
            "type": "number",
            "maximum": 100,
            "minimum": 0,
            "title": "Disk Usage"
          },
          "uptime_seconds": {
            "type": "number",
            "minimum": 0,
            "title": "Uptime Seconds"
          },
          "ip_address": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ip Address"
          },
          "extra_data": {
            "anyOf": [
              {
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Extra Data"
          }
        },
        "type": "object",
        "required": [
          "cpu_usage",
          "memory_usage",
