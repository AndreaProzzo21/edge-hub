      "get": {
        "tags": [
          "nodes"
        ],
        "summary": "Get Node Details",
        "description": "Retrieves detailed information, hardware metadata, and current status for a specific edge node.",
        "operationId": "get_node_api_v1_nodes__node_id__get",
        "parameters": [
          {
            "name": "node_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
