            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/api/v1/nodes/": {
      "get": {
        "tags": [
          "nodes"
        ],
        "summary": "List All Nodes",
        "description": "Retrieves a comprehensive list of all edge nodes registered across all sites in the entire fleet.",
        "operationId": "list_all_nodes_api_v1_nodes__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
