      "get": {
        "tags": [
          "nodes"
        ],
        "summary": "Get Node Telemetry History",
        "description": "Retrieves the last N historical telemetry records (heartbeats) for a specific node, ordered from the most recent to the oldest.",
        "operationId": "get_node_heartbeats_api_v1_nodes__node_id__heartbeats_get",
        "parameters": [
          {
            "name": "node_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Node Id"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/HeartbeatRecord"
                  },
                  "title": "Response Get Node Heartbeats Api V1 Nodes  Node Id  Heartbeats Get"
