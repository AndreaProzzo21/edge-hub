        "tags": [
          "nodes"
        ],
        "summary": "Revoke and Delete Node",
        "description": "Permanently deletes a node and cascades the deletion to all its historical heartbeat records. If the node is currently running, its JWT becomes invalid, forcing the remote agent to self-terminate on the next cycle.",
        "operationId": "remove_node_api_v1_nodes__node_id__delete",
        "parameters": [
          {
            "name": "node_id",
            "in": "path",
