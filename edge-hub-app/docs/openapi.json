            "name": "site_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Site Id"
            }
          },
          {
            "name": "token_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Token Id"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/agents/register": {
      "post": {
        "tags": [
          "agents"
        ],
        "summary": "Agent Registration Endpoint",
        "description": "Endpoint for edge agents to perform their initial provisioning. Consumes a valid single-use registration token and returns a permanent JWT for continuous telemetry streaming.",
