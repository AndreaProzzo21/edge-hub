                    "$ref": "#/components/schemas/TokenListItem"
                  },
                  "title": "Response List Tokens Api V1 Sites  Site Id  Tokens Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
