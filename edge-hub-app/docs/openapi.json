      "patch": {
        "tags": [
          "nodes"
        ],
        "summary": "Update Node Metadata",
        "description": "Allows administrative updates to a node's metadata, such as applying custom descriptions or tags.",
        "operationId": "patch_node_api_v1_nodes__node_id__patch",
        "parameters": [
          {
            "name": "node_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Node Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NodePatch"
              }
            }
